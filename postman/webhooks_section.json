{
  "name": "Webhooks",
  "item": [
    {
      "name": "Webhook Verification",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{APINOTIFICATION_URL}}/api/webhooks/meta?hub.mode=subscribe&hub.verify_token={{META_WEBHOOK_VERIFY_TOKEN}}&hub.challenge=challenge_accepted",
          "protocol": "https",
          "host": [
            "{{APINOTIFICATION_URL}}"
          ],
          "path": [
            "api",
            "webhooks",
            "meta"
          ],
          "query": [
            {
              "key": "hub.mode",
              "value": "subscribe"
            },
            {
              "key": "hub.verify_token",
              "value": "{{META_WEBHOOK_VERIFY_TOKEN}}"
            },
            {
              "key": "hub.challenge",
              "value": "challenge_accepted"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Webhook Inbound Message",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "X-Hub-Signature-256",
            "value": "sha256={{webhook_signature}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"object\": \"whatsapp_business_account\",\n  \"entry\": [\n    {\n      \"id\": \"{{waba_id}}\",\n      \"changes\": [\n        {\n          \"value\": {\n            \"messaging_product\": \"whatsapp\",\n            \"metadata\": {\n              \"display_phone_number\": \"{{display_phone_number}}\",\n              \"phone_number_id\": \"{{phone_number_id}}\"\n            },\n            \"contacts\": [\n              {\n                \"profile\": {\n                  \"name\": \"John Doe\"\n                },\n                \"wa_id\": \"16315551234\"\n              }\n            ],\n            \"messages\": [\n              {\n                \"id\": \"{{message_id}}\",\n                \"from\": \"16315551234\",\n                \"timestamp\": \"1624496825\",\n                \"text\": {\n                  \"body\": \"Hello there!\"\n                },\n                \"type\": \"text\"\n              }\n            ]\n          },\n          \"field\": \"messages\"\n        }\n      ]\n    }\n  ]\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{APINOTIFICATION_URL}}/api/webhooks/meta",
          "protocol": "https",
          "host": [
            "{{APINOTIFICATION_URL}}"
          ],
          "path": [
            "api",
            "webhooks",
            "meta"
          ]
        }
      },
      "response": []
    },
