{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "module": "commonjs",
        "target": "es2020",
        "lib": [
            "es2020"
        ],
        "moduleResolution": "node",
        "noEmit": false,
        "outDir": "dist",
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": [
        "src/gateway/**/*.ts"
    ]
}